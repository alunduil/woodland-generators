{
  "name": "woodland-generators",
  "version": "0.2.0",
  "description": "Workspace orchestrator for the Woodland Generators monorepo (core, foundry-module).",
  "author": "Alex Brandt",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0 <11.0.0"
  },
  "packageManager": "pnpm@10.34.5",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.3",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "10.7.0",
    "jest": "30.4.2",
    "knip": "6.26.0",
    "npm-check-updates": "22.2.9",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "6.0.3"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "rm -rf packages/*/dist/",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "pnpm -r test:coverage",
    "bench": "pnpm -r bench && pnpm exec tsx scripts/process-benchmarks.ts",
    "prepare": "pnpm run build",
    "check:outdated": "pnpm outdated",
    "update:deps": "ncu"
  }
}
