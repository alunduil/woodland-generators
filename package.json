{
  "name": "woodland-generators",
  "version": "0.1.0",
  "description": "CLI tool for generating resources for Root: The Tabletop RPG",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "woodland-gen": "dist/cli.js"
  },
  "author": "Alex Brandt",
  "license": "MIT",
  "keywords": [
    "root",
    "rpg",
    "tabletop",
    "generator",
    "cli",
    "character-generator",
    "npc-generator",
    "clearing-generator",
    "woodland",
    "leder-games",
    "pdf",
    "random-generator"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.0",
    "graphemer": "^1.4.0",
    "just-percentile": "^4.2.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.1",
    "seeded-random-utilities": "^1.1.4"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@types/jest": "29.5.14",
    "@types/node": "24.12.2",
    "@types/pdf-parse": "1.1.5",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "depcheck": "1.4.7",
    "eslint": "9.39.4",
    "fast-check": "4.7.0",
    "glob": "13.0.6",
    "jest": "29.7.0",
    "jest-bench": "29.7.1",
    "jest-junit": "17.0.0",
    "npm-check-updates": "18.3.1",
    "prettier": "3.8.3",
    "ts-jest": "29.4.9",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "cli": "pnpm run build && node dist/cli.js",
    "clean": "rm -rf dist/",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "bench": "jest --config jest.benchmark.config.json && tsx scripts/process-benchmarks.ts",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run check:all",
    "prepack": "pnpm run clean && pnpm run build",
    "postversion": "git push && git push --tags",
    "check:all": "pnpm run check:types && pnpm run check:lint && pnpm run check:format && pnpm run check:deps && pnpm run test",
    "check:types": "tsc --noEmit",
    "check:lint": "eslint src/",
    "check:format": "prettier --check src/**/*.ts",
    "check:deps": "depcheck",
    "check:outdated": "pnpm outdated",
    "check:workspace": "tsx scripts/validate-workspace.ts",
    "fix:lint": "eslint src/ --fix",
    "fix:format": "prettier --write src/**/*.ts",
    "update:deps": "ncu",
    "sync:deps": "tsx scripts/sync-precommit-deps.ts"
  }
}
