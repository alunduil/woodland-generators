{
  "name": "woodland-generators",
  "version": "0.2.0",
  "description": "Workspace orchestrator for the Woodland Generators monorepo (core, cli, foundry-module).",
  "author": "Alex Brandt",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "depcheck": "1.4.7",
    "eslint": "10.3.0",
    "jest": "30.3.0",
    "jest-junit": "17.0.0",
    "npm-check-updates": "22.1.0",
    "prettier": "3.8.3",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "scripts": {
    "build": "pnpm -r build",
    "cli": "pnpm --filter @woodland-generators/cli run build && node packages/cli/dist/cli.js",
    "clean": "rm -rf packages/*/dist/ coverage/ test-results/",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "bench": "pnpm -r bench && pnpm exec tsx scripts/process-benchmarks.ts",
    "prepare": "pnpm run build",
    "check:outdated": "pnpm outdated",
    "update:deps": "ncu"
  }
}
