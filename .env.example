# Copy to .env (gitignored) and set FOUNDRY_RELEASE_URL before the FIRST
# `docker compose up`. After one successful run the Foundry build and signed
# license are cached in the foundry-data volume, so later runs need no .env at
# all — as long as you stop with `docker compose down` (not `down -v`).

# REQUIRED on first run: a timed download link for the Foundry build. Generate
# it from your Foundry account -> Purchased Software Licenses -> set OS to
# "Node.js" -> click the timed URL button. It expires, so generate it right
# before `docker compose up`.
FOUNDRY_RELEASE_URL=

# OPTIONAL: write the license on first run instead of typing it in the browser.
# May still need a one-time browser signature to activate.
# FOUNDRY_LICENSE_KEY=

# OPTIONAL: locks the running instance's /setup screens. Safe to omit on
# localhost; set any value to require it.
# FOUNDRY_ADMIN_KEY=

# Fallback instead of FOUNDRY_RELEASE_URL. Puts your password on disk, so
# prefer the release URL above. Ignored if FOUNDRY_RELEASE_URL is set.
# FOUNDRY_USERNAME=
# FOUNDRY_PASSWORD=
