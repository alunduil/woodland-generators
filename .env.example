# Copy to .env and fill in. .env is gitignored.
# Used by docker-compose.yml to supply the Foundry build to the
# felddy/foundryvtt image. Choose ONE of the two auth methods below.

# Method A (no password on disk): a timed download URL.
# Generate it from your Foundry account -> Purchased Software Licenses ->
# set OS to "Node.js" -> click the timed URL button. It expires, so
# generate it right before `docker compose up`. Takes priority over the
# username/password below if both are set.
# FOUNDRY_RELEASE_URL=

# Method B: foundryvtt.com account credentials. Only needed if you are
# not using FOUNDRY_RELEASE_URL above.
FOUNDRY_USERNAME=
FOUNDRY_PASSWORD=

# Admin password for the running Foundry instance's /setup endpoints.
# Anything; you'll type this into the browser when prompted.
FOUNDRY_ADMIN_KEY=

# Optional: pin a specific license key (rather than your account default).
# A license key alone can't download a build; pair it with method A or B.
# FOUNDRY_LICENSE_KEY=
