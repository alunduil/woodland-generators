# Copy to .env and fill in. .env is gitignored.
# Used by docker-compose.yml to authenticate the felddy/foundryvtt image
# against your foundryvtt.com account.

# foundryvtt.com account credentials. Required.
FOUNDRY_USERNAME=
FOUNDRY_PASSWORD=

# Admin password for the running Foundry instance's /setup endpoints.
# Anything; you'll type this into the browser when prompted.
FOUNDRY_ADMIN_KEY=

# Optional: pin a specific license key (rather than your account default).
# FOUNDRY_LICENSE_KEY=
