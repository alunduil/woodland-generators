{
  "displayName": "core",
  "preset": "ts-jest",
  "testEnvironment": "node",
  "clearMocks": true,
  "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.d.ts"],
  "testPathIgnorePatterns": ["/node_modules/", "/dist/", ".*\\.bench\\.ts$"],
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.test.json"
      }
    ]
  }
}
