{
  "name": "@woodland-generators/cli",
  "version": "0.0.0",
  "description": "Thin CLI dispatching to @woodland-generators/core for headless verification and scripting",
  "bin": {
    "woodland-gen": "dist/cli.js"
  },
  "author": "Alex Brandt",
  "license": "MIT",
  "private": true,
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@woodland-generators/core": "workspace:*",
    "commander": "^14.0.0",
    "pino": "^10.0.0"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "jest": "30.3.0",
    "jest-junit": "17.0.0",
    "ts-jest": "29.4.9",
    "typescript": "5.9.3"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist/",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  }
}
