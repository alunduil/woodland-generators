{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"],
      "project": ["scripts/**/*.ts"],
      "ignoreDependencies": ["jest", "prettier"]
    },
    "packages/core": {
      "entry": [
        "src/logging/pino-pretty-transport.js",
        "test/**/*.test.ts",
        "test/**/*.bench.ts"
      ],
      "project": ["src/**/*.{ts,js}"]
    },
    "packages/foundry-module": {
      "entry": ["src/module.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
